{% extends 'base.html.twig' %}

{% block title %}
    {% if is_edit %}Modifier événement{% else %}Créer événement{% endif %}
{% endblock %}

{% block body %}
    <section class="form-card">
        <span class="badge">
            {% if is_edit %}Modification{% else %}Création{% endif %}
        </span>

        <h1 class="page-title">
            {% if is_edit %}Modifier un événement{% else %}Créer un événement{% endif %}
        </h1>

        <p class="page-subtitle">
            Remplissez les informations ci-dessous pour {% if is_edit %}mettre à jour{% else %}ajouter{% endif %} un événement.
        </p>

        <form method="post"
              action="{% if is_edit %}{{ path('admin_events_update', {id: event.id}) }}{% else %}{{ path('admin_events_create') }}{% endif %}"
              enctype="multipart/form-data"
              class="mt-2">

            <div class="grid grid-2">
                <div class="form-group">
                    <label for="title">Titre</label>
                    <input type="text" id="title" name="title" required value="{{ event ? event.title : '' }}" placeholder="Nom de l'événement">
                </div>

                <div class="form-group">
                    <label for="location">Lieu</label>
                    <input type="text" id="location" name="location" required value="{{ event ? event.location : '' }}" placeholder="Lieu de l'événement">
                </div>
            </div>

            <div class="form-group">
                <label for="description">Description</label>
                <textarea id="description" name="description" required placeholder="Décrivez votre événement...">{{ event ? event.description : '' }}</textarea>
            </div>

            <div class="grid grid-2">
                <div class="form-group">
                    <label for="seats">Nombre de places</label>
                    <input type="number" id="seats" name="seats" min="1" required value="{{ event ? event.seats : '' }}">
                </div>

                <div class="form-group">
                    <label for="date">Date</label>
                    <input type="datetime-local"
                           id="date"
                           name="date"
                           required
                           value="{{ event and event.date ? event.date|date('Y-m-d\\TH:i') : '' }}">
                </div>
            </div>

            <div class="form-group">
                <label for="image">Image</label>
                <input type="file" id="image" name="image" accept="image/*">
            </div>

            {% if is_edit and event.image %}
                <div class="file-preview">
                    <p class="mb-1"><strong>Image actuelle :</strong></p>
                    <img src="{{ asset('uploads/' ~ event.image) }}" alt="{{ event.title }}">
                </div>
            {% endif %}

            <div class="actions-row mt-2">
                <button type="submit" class="btn btn-primary">
                    {% if is_edit %}Mettre à jour{% else %}Créer{% endif %}
                </button>
                <a href="{{ path('admin_events_index') }}" class="btn btn-secondary">Retour à la liste</a>
            </div>
        </form>
    </section>
{% endblock %}