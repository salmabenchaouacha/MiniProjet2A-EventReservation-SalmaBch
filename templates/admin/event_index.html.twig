{% extends 'base.html.twig' %}

{% block title %}Gestion des événements{% endblock %}

{% block body %}
    <section class="mb-2">
        <span class="badge">Back-office</span>
        <h1 class="page-title">Gestion des événements</h1>
        <p class="page-subtitle">
            Consultez, modifiez ou supprimez les événements depuis une interface claire et moderne.
        </p>

        <div class="actions-row mt-1">
            <a href="{{ path('admin_events_new') }}" class="btn btn-primary">Créer un nouvel événement</a>
            <a href="{{ path('admin_dashboard') }}" class="btn btn-secondary">Retour au dashboard</a>
        </div>
    </section>

    {% if events is empty %}
        <div class="glass-card empty-state">
            <h2>Aucun événement trouvé</h2>
            <p>Commencez par créer votre premier événement.</p>
        </div>
    {% else %}
        <div class="table-card">
            <table>
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Image</th>
                        <th>Titre</th>
                        <th>Lieu</th>
                        <th>Date</th>
                        <th>Places</th>
                        <th>Disponibles</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for event in events %}
                        <tr>
                            <td>#{{ event.id }}</td>
                            <td>
                                {% if event.image %}
                                    <img class="table-thumb" src="{{ asset('uploads/' ~ event.image) }}" alt="{{ event.title }}">
                                {% else %}
                                    <span class="muted">Aucune</span>
                                {% endif %}
                            </td>
                            <td>{{ event.title }}</td>
                            <td>{{ event.location }}</td>
                            <td>{{ event.date ? event.date|date('d/m/Y H:i') : '' }}</td>
                            <td>{{ event.seats }}</td>
                            <td>{{ event.availableSeats }}</td>
                            <td>
                                <div class="table-actions">
                                    <a href="{{ path('admin_events_edit', {id: event.id}) }}" class="btn btn-secondary">Modifier</a>

                                    <form method="post"
                                          action="{{ path('admin_events_delete', {id: event.id}) }}"
                                          class="inline-form"
                                          onsubmit="return confirm('Supprimer cet événement ?');">
                                        <button type="submit" class="btn btn-danger">Supprimer</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    {% endif %}
{% endblock %}