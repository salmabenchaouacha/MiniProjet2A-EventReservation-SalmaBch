{% extends 'base.html.twig' %}

{% block title %}Dashboard Admin{% endblock %}

{% block body %}
    <section class="dashboard-card">
        <span class="badge">Administration</span>
        <h1 class="page-title">Dashboard administrateur</h1>
        <p class="page-subtitle">
            Gérez les événements, suivez les réservations et mettez à jour votre plateforme depuis cet espace.
        </p>

        <div class="stats-grid">
            <div class="stat-card">
                <h3>⚡</h3>
                <p>Gestion rapide des événements</p>
            </div>
            <div class="stat-card">
                <h3>🎫</h3>
                <p>Suivi des places disponibles</p>
            </div>
            <div class="stat-card">
                <h3>📅</h3>
                <p>Organisation claire et moderne</p>
            </div>
        </div>

        <div class="actions-row mt-2">
            <a href="{{ path('admin_events_index') }}" class="btn btn-primary">Gérer les événements</a>
            <a href="{{ path('admin_events_new') }}" class="btn btn-secondary">Ajouter un événement</a>
        </div>
    </section>
{% endblock %}