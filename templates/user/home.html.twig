{% extends 'base.html.twig' %}

{% block title %}Accueil{% endblock %}

{% block body %}
   
    <section class="mt-2">
        <span class="badge">Événements disponibles</span>
        <h2 class="page-title" style="font-size: 2.2rem;">Découvrez les événements à venir</h2>
        <p class="page-subtitle">
            Réservez votre place parmi les événements actuellement disponibles.
        </p>

        <div class="glass-card mt-2" style="padding: 1.5rem;">
            <div class="filters-form" style="display:grid; grid-template-columns:repeat(auto-fit,minmax(220px,1fr)); gap:1rem; align-items:end;">
                <div>
                    <label for="filter-title">Titre</label>
                    <input type="text" id="filter-title" class="form-control" placeholder="Rechercher par titre">
                </div>

                <div>
                    <label for="filter-location">Lieu</label>
                    <input type="text" id="filter-location" class="form-control" placeholder="Rechercher par lieu">
                </div>

                <div>
                    <label for="filter-date">Date</label>
                    <input type="date" id="filter-date" class="form-control">
                </div>

                <div>
                    <button type="button" id="reset-filters" class="btn btn-secondary">Réinitialiser</button>
                </div>
            </div>
        </div>

        {% if events is empty %}
            <div class="glass-card empty-state mt-2">
                <h3>Aucun événement disponible</h3>
                <p>Revenez bientôt pour découvrir les prochaines activités.</p>
            </div>
        {% else %}
            <div class="events-grid" id="events-grid">
                {% for event in events %}
                    <article
                        class="event-card"
                        data-title="{{ event.title|lower }}"
                        data-location="{{ event.location|lower }}"
                        data-date="{{ event.date|date('Y-m-d') }}"
                    >
                        {% if event.image %}
                            <img class="event-card-image" src="{{ event.image }}" alt="{{ event.title }}">
                        {% else %}
                            <img class="event-card-image" src="https://placehold.co/600x400?text=Event" alt="{{ event.title }}">
                        {% endif %}

                        <div class="event-card-body">
                            <h3>{{ event.title }}</h3>

                            <p class="event-description">
                                {{ event.description|length > 120 ? event.description|slice(0, 120) ~ '...' : event.description }}
                            </p>

                            <div class="event-meta">
                                <span><strong>Date :</strong> {{ event.date|date('d/m/Y H:i') }}</span>
                                <span><strong>Lieu :</strong> {{ event.location }}</span>
                                <span><strong>Places restantes :</strong> {{ event.availableSeats }}</span>
                            </div>

                            <a href="{{ path('app_event_show', {id: event.id}) }}" class="btn btn-primary">
                                Voir détail
                            </a>
                        </div>
                    </article>
                {% endfor %}
            </div>

            <div id="no-results" class="glass-card empty-state mt-2" style="display:none;">
                <h3>Aucun résultat</h3>
                <p>Aucun événement ne correspond aux filtres sélectionnés.</p>
            </div>
        {% endif %}
    </section>

    <script>
        const titleInput = document.getElementById('filter-title');
        const locationInput = document.getElementById('filter-location');
        const dateInput = document.getElementById('filter-date');
        const resetButton = document.getElementById('reset-filters');
        const cards = document.querySelectorAll('.event-card');
        const noResults = document.getElementById('no-results');

        function filterEvents() {
            const titleValue = titleInput.value.trim().toLowerCase();
            const locationValue = locationInput.value.trim().toLowerCase();
            const dateValue = dateInput.value;

            let visibleCount = 0;

            cards.forEach(card => {
                const title = card.dataset.title;
                const location = card.dataset.location;
                const date = card.dataset.date;

                const matchTitle = !titleValue || title.includes(titleValue);
                const matchLocation = !locationValue || location.includes(locationValue);
                const matchDate = !dateValue || date === dateValue;

                if (matchTitle && matchLocation && matchDate) {
                    card.style.display = 'block';
                    visibleCount++;
                } else {
                    card.style.display = 'none';
                }
            });

            if (noResults) {
                noResults.style.display = visibleCount === 0 ? 'block' : 'none';
            }
        }

        if (titleInput) titleInput.addEventListener('input', filterEvents);
        if (locationInput) locationInput.addEventListener('input', filterEvents);
        if (dateInput) dateInput.addEventListener('input', filterEvents);

        if (resetButton) {
            resetButton.addEventListener('click', () => {
                titleInput.value = '';
                locationInput.value = '';
                dateInput.value = '';
                filterEvents();
            });
        }
    </script>
{% endblock %}