<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Event Reservation{% endblock %}</title>

    <link rel="stylesheet" href="{{ asset('css/app.css') }}">
    <script src="{{ asset('js/auth.js') }}" defer></script>

    {% block stylesheets %}{% endblock %}
</head>

<body class="{% block body_class %}{% endblock %}">
    <header class="site-header">
        <div class="container nav-wrapper">
            <a href="{{ path('app_home') }}" class="logo">
                <img src="{{ asset('logoo.png') }}" alt="Eventify Logo" class="logo-img">
            </a>

            <nav class="main-nav">
                {% if app.user %}
                    {% if is_granted('ROLE_ADMIN') %}
                        <a href="{{ path('admin_dashboard') }}">Dashboard Admin</a>
                        <button type="button" id="add-passkey-btn" class="btn-passkey">Ajouter passkey</button>
                        <a href="{{ path('app_logout') }}">Se déconnecter</a>
                    {% else %}
                        <span>{{ app.user.email }}</span>
                        <button type="button" id="add-passkey-btn" class="btn-passkey">Ajouter passkey</button>
                        <a href="{{ path('app_logout') }}">Se déconnecter</a>
                    {% endif %}
                {% else %}
                    <a href="{{ path('app_user_login') }}">Connexion</a>
                    <a href="{{ path('app_login') }}">Dashboard Admin</a>
                {% endif %}
            </nav>
        </div>
    </header>

    <main class="page">
        <div class="container">
            {% for message in app.flashes('success') %}
                <div class="alert alert-success">{{ message }}</div>
            {% endfor %}

            {% for message in app.flashes('error') %}
                <div class="alert alert-danger">{{ message }}</div>
            {% endfor %}

            {% block body %}{% endblock %}
        </div>
    </main>

    <footer class="site-footer">
        <div class="container footer-content">
            <p>© {{ "now"|date("Y") }} EVENTIFY. Tous droits réservés.</p>
        </div>
    </footer>

    {% block javascripts %}{% endblock %}
</body>
</html>