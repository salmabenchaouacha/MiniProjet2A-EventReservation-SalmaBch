{% extends 'base.html.twig' %}

{% block title %}Connexion utilisateur{% endblock %}

{% block body %}
    <section class="auth-wrapper">
        <div class="auth-card">
            <div class="text-center mb-2">
                <span class="badge">Espace utilisateur</span>
                <h1 class="page-title">Connexion</h1>
                <p class="page-subtitle">
                    Connectez-vous avec votre email / mot de passe ou avec votre passkey.
                </p>
            </div>

            {% if error %}
                <div class="alert alert-danger">
                    {{ error.messageKey|trans(error.messageData, 'security') }}
                </div>
            {% endif %}

            <form method="post" action="{{ path('app_login') }}">
                <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">
                <input type="hidden" name="login_source" value="user">

                <div class="form-group">
                    <label for="email">Email</label>
                    <input
                        type="email"
                        id="email"
                        name="email"
                        value="{{ last_username }}"
                        required
                        autofocus
                        placeholder="Votre adresse email"
                    >
                </div>

                <div class="form-group">
                    <label for="password">Mot de passe</label>
                    <input
                        type="password"
                        id="password"
                        name="password"
                        required
                        placeholder="Votre mot de passe"
                    >
                </div>

                <button type="submit" class="btn btn-primary">Connexion par mot de passe</button>
            </form>

            <div class="text-center mt-2 mb-1 muted">ou</div>

            <button type="button" onclick="loginWithPasskey()" class="btn btn-secondary">
                Connexion avec Passkey
            </button>

            <p id="login-message" class="mt-1 text-center muted"></p>

            <div class="text-center mt-2">
                <p>
                    Vous n’avez pas de compte ?
                    <a href="{{ path('app_register_page') }}" style="color:#c4b5fd;">Inscrivez-vous</a>
                </p>
            </div>
        </div>
    </section>

    <script>
        async function loginWithPasskey() {
            try {
                const result = await loginWithPasskeyRequest();

                document.getElementById('login-message').innerText =
                    result.message || 'Connexion réussie';

                if (result.redirect) {
                    window.location.href = result.redirect;
                    return;
                }

                window.location.href = '{{ path('app_home') }}';
            } catch (e) {
                document.getElementById('login-message').innerText =
                    e.message || 'Erreur de connexion avec passkey';
            }
        }
    </script>
{% endblock %}